{
  "name": "@w5s/object-id",
  "version": "1.0.0-alpha.0",
  "description": "Unique identifier of object-like values (object, symbol, function)",
  "keywords": [
    "fp",
    "functional",
    "object-id",
    "objectid"
  ],
  "homepage": "https://github.com/w5s/std/tree/master/packages/object-id#readme",
  "bugs": {
    "url": "https://github.com/w5s/std/issues"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:w5s/std.git",
    "directory": "packages/object-id"
  },
  "license": "MIT",
  "author": "Julien Polo <julien.polo@gmail.com>",
  "type": "module",
  "exports": {
    "./package.json": "./package.json",
    ".": "./dist/index.js",
    "./dist/*": "./dist/*",
    "./internal/*": null
  },
  "files": [
    "dist/",
    "src/",
    "!**/*.spec.*",
    "!**/__tests__/**"
  ],
  "scripts": {
    "build": "pnpm run \"/^build:.*/\"",
    "build:tsc": "tsdown",
    "clean": "pnpm run \"/^clean:.*/\"",
    "clean:tsc": "rm -rf dist",
    "docs": "node '../../markdown.mjs'",
    "format": "pnpm run \"/^format:.*/\"",
    "format:src": "eslint . --fix",
    "lint": "pnpm run \"/^lint:.*/\"",
    "lint:src": "eslint .",
    "size-limit": "size-limit",
    "spellcheck": "cspell --no-progress '**'",
    "test": "pnpm run \"/^test:.*/\"",
    "test:src": "vitest run",
    "tsc": "tsc",
    "typecheck": "tsc --noEmit -p tsconfig.build.json",
    "validate": "npm run lint && npm run build && npm run test"
  },
  "dependencies": {
    "@w5s/core-type": "workspace:^1.0.0-alpha.0",
    "@w5s/global-storage": "workspace:^1.0.0-alpha.0"
  },
  "devDependencies": {
    "@w5s/tsdown-config": "1.0.0-alpha.6",
    "tsdown": "0.22.3",
    "typescript": "6.0.3",
    "vitest": "latest"
  },
  "peerDependencies": {
    "typescript": "^3.8.0 || ^4.0.0 || ^5.0.0 || ^6.0.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "size-limit": [
    {
      "path": "dist/index.js",
      "limit": "1 kB"
    }
  ],
  "sideEffect": false
}
