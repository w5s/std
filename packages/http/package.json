{
  "name": "@w5s/http",
  "version": "1.0.0-alpha.0",
  "description": "HTTP client module",
  "keywords": [
    "fp",
    "functional",
    "http",
    "client",
    "fetch"
  ],
  "homepage": "https://github.com/w5s/std/tree/master/packages/http#readme",
  "bugs": {
    "url": "https://github.com/w5s/std/issues"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:w5s/std.git",
    "directory": "packages/http"
  },
  "license": "MIT",
  "author": "Julien Polo <julien.polo@gmail.com>",
  "type": "module",
  "exports": {
    ".": "./dist/index.js",
    "./dist/*": "./dist/*"
  },
  "typings": "./dist/index.d.ts",
  "files": [
    "dist/",
    "src/",
    "!*.d.ts.map",
    "!**/*.spec.*",
    "!**/__tests__/**"
  ],
  "scripts": {
    "build": "pnpm run \"/^build:.*/\"",
    "build:tsc": "tsc -b tsconfig.build.json",
    "clean": "pnpm run \"/^clean:.*/\"",
    "clean:tsc": "rm -rf dist",
    "docs": "node '../../markdown.mjs'",
    "format": "pnpm run \"/^format:.*/\"",
    "format:src": "eslint . --fix",
    "lint": "pnpm run \"/^lint:.*/\"",
    "lint:src": "eslint .",
    "prebuild:tsc": "node scripts/buildStatus.js",
    "prepublishOnly": "npm run clean;npm run build",
    "size-limit": "size-limit",
    "spellcheck": "cspell --no-progress '**'",
    "test": "pnpm run \"/^test:.*/\"",
    "test:src": "vitest run",
    "tsc": "tsc",
    "validate": "npm run build && npm run test"
  },
  "dependencies": {
    "@w5s/core": "workspace:^1.0.0-alpha.0",
    "@w5s/core-type": "workspace:^1.0.0-alpha.0",
    "@w5s/error": "workspace:^1.0.0-alpha.0",
    "@w5s/num": "workspace:^1.0.0-alpha.0",
    "@w5s/task": "workspace:^1.0.0-alpha.0",
    "@w5s/task-timeout": "workspace:^1.0.0-alpha.0",
    "@w5s/time": "workspace:^1.0.0-alpha.0"
  },
  "devDependencies": {
    "typescript": "6.0.3",
    "vitest": "latest"
  },
  "peerDependencies": {
    "typescript": "^3.8.0 || ^4.0.0 || ^5.0.0 || ^6.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "size-limit": [
    {
      "path": "dist/index.js",
      "limit": "7 kB"
    }
  ],
  "sideEffect": false
}
