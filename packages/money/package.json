{
  "name": "@w5s/money",
  "version": "1.0.0-alpha.0",
  "description": "Money module",
  "keywords": [
    "fp",
    "functional",
    "task",
    "money"
  ],
  "homepage": "https://github.com/w5s/std/tree/master/packages/money#readme",
  "bugs": {
    "url": "https://github.com/w5s/std/issues"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:w5s/std.git",
    "directory": "packages/money"
  },
  "license": "MIT",
  "author": "Julien Polo <julien.polo@gmail.com>",
  "type": "module",
  "exports": {
    "./package.json": "./package.json",
    ".": "./dist/index.js",
    "./dist/*": "./dist/*",
    "./internal/*": null
  },
  "files": [
    "dist/",
    "src/",
    "!**/*.spec.*",
    "!**/__tests__/**"
  ],
  "scripts": {
    "build": "pnpm run \"/^build:.*/\"",
    "build:tsc": "tsc -b tsconfig.build.json",
    "clean": "pnpm run \"/^clean:.*/\"",
    "clean:tsc": "rm -rf dist",
    "docs": "node '../../markdown.mjs'",
    "format": "pnpm run \"/^format:.*/\"",
    "format:src": "eslint . --fix",
    "lint": "pnpm run \"/^lint:.*/\"",
    "lint:src": "eslint .",
    "prebuild:tsc": "node scripts/buildCurrencies.js",
    "prepublishOnly": "npm run clean;npm run build",
    "size-limit": "size-limit",
    "spellcheck": "cspell --no-progress '**'",
    "test": "pnpm run \"/^test:.*/\"",
    "test:src": "vitest run",
    "tsc": "tsc",
    "typecheck": "tsc --noEmit -p tsconfig.build.json",
    "validate": "npm run lint && npm run build && npm run test"
  },
  "dependencies": {
    "@w5s/application": "workspace:^1.0.0-alpha.0",
    "@w5s/bigdecimal": "workspace:^1.0.0-alpha.0",
    "@w5s/core": "workspace:^1.0.0-alpha.0",
    "@w5s/core-type": "workspace:^1.0.0-alpha.0",
    "@w5s/error": "workspace:^1.0.0-alpha.0"
  },
  "devDependencies": {
    "@w5s/tsdown-config": "1.0.0-alpha.12",
    "currencies.json": "1.1.0",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "typescript": "^3.8.0 || ^4.0.0 || ^5.0.0 || ^6.0.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "size-limit": [
    {
      "path": "dist/index.js",
      "limit": "10 kB"
    }
  ],
  "sideEffect": false
}
